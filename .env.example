# Public env vars (exposed to client). All optional — sensible defaults live in src/consts.ts.

# Formspree form IDs — optional overrides; default to the live forms in src/consts.ts.
PUBLIC_FORMSPREE_CONTACT_ID=
PUBLIC_FORMSPREE_DEMO_ID=
# Newsletter signup is handled by an EmailOctopus embed in the footer
# (see src/components/Footer.astro) — no Formspree ID needed.

# GA4 measurement ID — optional override; defaults to the live property in src/consts.ts.
# Set to an explicit empty value (PUBLIC_GA4_ID=) to DISABLE analytics + consent banner.
PUBLIC_GA4_ID=G-N1T9TZ6921

# Shopify App Store install URL — optional override.
# Defaults to https://apps.shopify.com/standard-parts-toolkit (see src/consts.ts).
PUBLIC_SHOPIFY_APP_URL=
