---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  effective: string;
}

const { title, description, effective } = Astro.props;
---

<BaseLayout title={`${title} — SPT`} description={description}>

  <article class="section pt-12 sm:pt-20">
    <div class="mx-auto max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--action)">Legal</p>
      <h1 class="mt-3 text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl" style="color: var(--text)">{title}</h1>
      <p class="mt-4 text-sm" style="color: var(--text-subtle)"><strong>Effective:</strong> {effective}</p>

      <div class="legal-body mt-10">
        <slot />
      </div>
    </div>
  </article>

</BaseLayout>

<style is:global>
  .legal-body {
    color: var(--text);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .legal-body h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: -0.015em;
    margin: 2.25rem 0 0.5rem;
    color: var(--text);
  }
  .legal-body h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    margin: 1.5rem 0 0.4rem;
    color: var(--text);
  }
  .legal-body p { margin: 0.75rem 0; }
  .legal-body ul, .legal-body ol { margin: 0.75rem 0; padding-left: 1.5rem; }
  .legal-body ul li { list-style: disc; margin: 0.4rem 0; }
  .legal-body a { color: var(--primary); text-decoration: underline; }
  .legal-body code {
    font-family: var(--font-mono);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1em 0.4em;
    font-size: 0.9em;
  }
</style>
