---
import BaseLayout from './BaseLayout.astro';
import DualCTA from '../components/DualCTA.astro';

interface Step { step: string; body: string; }
interface Faq  { q: string; a: string; }

interface Props {
  eyebrow: string;
  headline: string;
  subhead: string;
  /** Optional new-feature badge */
  isNew?: boolean;
  /** Optional hero screenshot. When omitted, the hero is a full-width text block. */
  heroImage?: string;
  /** Alt text for the hero screenshot (defaults to the caption). */
  heroImageAlt?: string;
  /** Optional caption under the hero screenshot */
  heroCaption?: string;
  howItWorks: Step[];
  configurable: string[];
  /** Short paragraph naming the data sources that power this feature */
  dataSources?: string;
  faqs: Faq[];
  /** Page metadata */
  title: string;
  description: string;
}

const {
  eyebrow,
  headline,
  subhead,
  isNew = false,
  heroImage,
  heroImageAlt,
  heroCaption = 'Annotated product screenshot.',
  howItWorks,
  configurable,
  dataSources,
  faqs,
  title,
  description,
} = Astro.props;
---

<BaseLayout title={title} description={description}>

  <!-- HERO -->
  <section class="section pt-12 sm:pt-20">
    <div class={heroImage ? 'grid items-center gap-10 lg:grid-cols-12' : ''}>
      <div class={heroImage ? 'lg:col-span-7' : 'max-w-4xl'}>
        <div class="flex flex-wrap items-center gap-3">
          <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--action)">{eyebrow}</p>
          {isNew && <span class="tag tag-action">New</span>}
        </div>
        <h1 class="mt-3 text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl" style="color: var(--text)">
          {headline}
        </h1>
        <p class="lede mt-5 max-w-2xl">{subhead}</p>
        <div class="mt-8"><DualCTA variant="inline" showDemoLink={false} /></div>
      </div>
      {heroImage && (
        <div class="lg:col-span-5">
          <figure class="overflow-hidden rounded-2xl border" style="border-color: var(--border); background: var(--surface)">
            <img
              src={heroImage}
              alt={heroImageAlt ?? heroCaption}
              width="1200"
              height="960"
              loading="eager"
              decoding="async"
              class="aspect-[5/4] w-full object-cover"
            />
            <figcaption class="px-4 py-3 text-sm" style="color: var(--text-muted)">{heroCaption}</figcaption>
          </figure>
        </div>
      )}
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section style="background: var(--surface-2)">
    <div class="section">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">How it works</h2>
      <ol class="mt-8 grid gap-5 sm:grid-cols-3">
        {howItWorks.map((s, i) => (
          <li class="card">
            <div
              class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-full text-sm font-bold"
              style="background: var(--primary); color: var(--primary-fg)"
            >{i + 1}</div>
            <div class="text-base font-semibold" style="color: var(--text)">{s.step}</div>
            <p class="mt-2 text-sm" style="color: var(--text-muted)">{s.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- WHAT YOU CAN CONFIGURE + DATA SOURCES + SLOT -->
  <section class="section">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">What you can configure</h2>
        <ul class="mt-6 space-y-3">
          {configurable.map((c) => (
            <li class="flex items-start gap-3">
              <span class="mt-1 inline-block h-2 w-2 flex-none rounded-full" style="background: var(--primary)"></span>
              <span class="text-base" style="color: var(--text)" set:html={c}></span>
            </li>
          ))}
        </ul>
      </div>
      {dataSources && (
        <aside class="lg:col-span-5">
          <div class="card" style="background: var(--primary-soft); border-color: color-mix(in srgb, var(--primary) 25%, transparent)">
            <span class="tag tag-primary">Powered by</span>
            <p class="mt-3 text-sm" style="color: var(--text)" set:html={dataSources}></p>
            <a href="/integrations/" class="mt-4 inline-flex items-center gap-1 text-sm font-semibold" style="color: var(--primary)">
              See all data sources <span aria-hidden="true">→</span>
            </a>
          </div>
          <slot name="aside-extra" />
        </aside>
      )}
    </div>

    <slot name="extra-section" />
  </section>

  <!-- FAQ -->
  {faqs.length > 0 && (
    <section style="background: var(--surface-2)">
      <div class="section">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Frequently asked questions</h2>
        <dl class="mt-8 grid gap-4 sm:grid-cols-2">
          {faqs.map((f) => (
            <div class="card">
              <dt class="text-base font-semibold" style="color: var(--text)">{f.q}</dt>
              <dd class="mt-2 text-sm" style="color: var(--text-muted)" set:html={f.a}></dd>
            </div>
          ))}
        </dl>
      </div>
    </section>
  )}

  <DualCTA />

</BaseLayout>
