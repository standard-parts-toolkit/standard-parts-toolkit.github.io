---
import BaseLayout from '../layouts/BaseLayout.astro';
import DualCTA from '../components/DualCTA.astro';

const values = [
  {
    title: 'Specifics over slogans.',
    body: 'We build features and answer support tickets with the actual details.',
  },
  {
    title: 'Configurable, not opinionated.',
    body: 'Your store, your catalog, your workflow. We expose settings; you make the calls.',
  },
  {
    title: 'Boring is beautiful.',
    body: "Sync runs that just work. Search that submits cleanly. Data that syncs effortlessly. We're not chasing novelty.",
  },
];
---

<BaseLayout
  title="About — SPT"
  description="SPT (Standard Parts Toolkit) is a product of No Fixed Plans Inc. The toolkit your Shopify automotive parts store has been missing."
>

  <section class="section pt-12 sm:pt-20">
    <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--action)">About</p>
    <h1 class="mt-3 max-w-4xl text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl" style="color: var(--text)">
      We build the automotive specific features your Shopify store has been missing.
    </h1>
    <p class="lede mt-5 max-w-3xl">
      SPT is a focused team on one thing: making the boring, hard, structural parts of selling automotive parts on
      Shopify actually work.
    </p>
  </section>

  <section style="background: var(--surface-2)">
    <div class="section">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Who we are</h2>
      <p class="lede mt-4 max-w-3xl">
        <strong style="color: var(--text)">SPT</strong> (short for <em>Standard Parts Toolkit</em>) is a product of
        <a href="https://nofixedplans.xyz/" target="_blank" rel="noopener" style="color: var(--primary)" class="underline">No Fixed Plans</a>.
      </p>
      <p class="lede mt-4 max-w-3xl">
        We support several parts-data sources out of the box — including
        <a href="https://info.showmetheparts.com/" target="_blank" rel="noopener" style="color: var(--primary)" class="underline">ShowMeTheParts</a>
        (operated by Vertical Development), ACES/PIES files you provide, and CSV uploads — so merchants can use
        whichever feed matches how they already operate.
      </p>
    </div>
  </section>

  <section class="section">
    <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Our story</h2>
    <div class="mt-6 grid gap-6 lg:grid-cols-2">
      <p class="lede">
        Most ecommerce tooling assumes a clean catalog and a simple "search for a t-shirt" UX. Automotive parts
        don't work that way. The catalog is huge, the fitment relationships are messy, the data lives in ACES/PIES
        files most platforms don't understand, and the order flow has to land in warehouses and ERPs that were
        written before the modern web.
      </p>
      <p class="lede">
        We built SPT because the gap between "automotive parts" and "Shopify" was being filled — store by store —
        by custom development projects that took quarters and broke on every theme upgrade. The toolkit replaces
        that custom build with a configurable, supported app.
      </p>
    </div>
  </section>

  <section style="background: var(--surface-2)">
    <div class="section">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">What we believe</h2>
      <div class="mt-8 grid gap-5 sm:grid-cols-3">
        {values.map((v) => (
          <div class="card">
            <h3 class="text-base font-bold" style="color: var(--text)">{v.title}</h3>
            <p class="mt-2 text-sm" style="color: var(--text-muted)">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Where to find us</h2>
        <p class="lede mt-4">
          <strong style="color: var(--text)">1449 S Michigan Ave STE 13288</strong><br/>
          Chicago, IL 60605
        </p>
        <p class="mt-3" style="color: var(--text-muted)">
          Or reach out via <a href="/contact/" style="color: var(--primary)" class="underline">contact</a>.
        </p>
      </div>
      <div class="lg:col-span-5">
        <div class="card">
          <h3 class="text-base font-bold" style="color: var(--text)">Want to see if we're a fit?</h3>
          <p class="mt-2 text-sm" style="color: var(--text-muted)">
            We'll run a sample of your ACES/PIES file, ShowMeTheParts feed, or CSV through the toolkit and walk
            you through the resulting search and product pages.
          </p>
          <a href="/demo/" class="btn btn-primary mt-4">Book a Demo</a>
        </div>
      </div>
    </div>
  </section>

  <DualCTA />

</BaseLayout>
