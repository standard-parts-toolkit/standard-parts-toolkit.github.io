---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DualCTA from '../../components/DualCTA.astro';
import HeroVisual from '../../components/HeroVisual.astro';

const sources = [
  {
    href: '/integrations/aces-pies/',
    tag: 'Manufacturer-grade',
    title: 'ACES / PIES',
    body: 'Industry-standard XML for fitment and product information. The most common source for parts manufacturers.',
    bullets: ['ACES 3.x and 4.x', 'PIES 6.x and 7.x', 'Full + incremental updates'],
  },
  {
    href: '/integrations/showmetheparts/',
    tag: 'API-driven',
    title: 'ShowMeTheParts',
    body: 'API-based fitment and parts data. Good fit for retailers without their own ACES/PIES feed. 800+ supplier brands available.',
    bullets: ['VIN + license plate lookup', 'Ongoing Updates'],
  },
  {
    href: '/integrations/csv/',
    tag: 'Lightweight',
    title: 'CSV',
    body: 'Bring your own spreadsheet or export. The fastest path for stores with a small or custom catalog.',
    bullets: ['Combined or separate files', 'Configurable column mapping', 'Validation per upload'],
  },
];

const channels = [
  { title: 'SFTP / FTP',         body: 'Supplier file drops for catalog and price/inventory, plus outbound order files.' },
  { title: 'Inbound email',      body: 'Attachment pickup for price & inventory, plus order delivery.' },
  { title: 'HTTP API',           body: 'Outbound order delivery to ERPs, 3PLs, and homegrown systems.' },
];
---

<BaseLayout
  title="Integrations — SPT"
  description="ACES/PIES, ShowMeTheParts, or CSV catalog data. SFTP, FTP, email, HTTP API, and ShowMeTheParts API channels. SPT plugs into the systems your supply chain already speaks."
>

  <section class="section pt-12 sm:pt-20">
    <div class="grid items-center gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--action)">
          Data sources &amp; channels
        </p>
        <h1 class="mt-3 text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl" style="color: var(--text)">
          Bring the data you already have. Stop duplicating effort.
        </h1>
        <p class="lede mt-5 max-w-2xl">
          SPT is data-source agnostic. Pick the catalog source that matches how you operate today, and connect to the
          ingestion and export channels your supply chain already speaks. Switch sources later without rebuilding your
          storefront — your YMM widget, PDP blocks, and admin settings carry over.
        </p>
      </div>
      <div class="lg:col-span-5">
        <HeroVisual variant="data-sources" />
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Primary data sources</h2>
    <div class="mt-6 grid gap-5 lg:grid-cols-3">
      {sources.map((s) => (
        <a href={s.href} class="card focus-ring group block transition-shadow hover:shadow-lg">
          <span class="tag tag-primary">{s.tag}</span>
          <h3 class="mt-3 text-lg font-bold" style="color: var(--text)">{s.title}</h3>
          <p class="mt-2 text-sm" style="color: var(--text-muted)">{s.body}</p>
          <ul class="mt-4 space-y-1.5 text-xs" style="color: var(--text-subtle)">
            {s.bullets.map((b) => (<li>· {b}</li>))}
          </ul>
          <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors group-hover:gap-2" style="color: var(--primary)">
            See details <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="section pt-0">
    <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Ingestion &amp; export channels</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-3">
      {channels.map((c) => (
        <div class="card">
          <h3 class="text-base font-bold" style="color: var(--text)">{c.title}</h3>
          <p class="mt-2 text-sm" style="color: var(--text-muted)">{c.body}</p>
        </div>
      ))}
    </div>
    <p class="mt-6 text-sm" style="color: var(--text-subtle)">
      Switch sources later without rebuilding your storefront. The configuration that drives your YMM search, PDP,
      and catalog sync is decoupled from the underlying connector.
    </p>
  </section>

  <DualCTA />

</BaseLayout>
