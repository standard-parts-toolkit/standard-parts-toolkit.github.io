---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DualCTA from '../../components/DualCTA.astro';
import HeroVisual from '../../components/HeroVisual.astro';
---

<BaseLayout
  title="ShowMeTheParts on Shopify — SPT"
  description="Connect your ShowMeTheParts account and SPT will sync parts, vehicles, and fitment from 1,000+ supplier brands into your Shopify storefront."
>

  <section class="section pt-12 sm:pt-20">
    <div class="grid items-center gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--action)">Integration · ShowMeTheParts</p>
        <h1 class="mt-3 text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl" style="color: var(--text)">
          ShowMeTheParts data, live on your Shopify storefront.
        </h1>
        <p class="lede mt-5 max-w-2xl">
          Connect your ShowMeTheParts account and SPT will sync the parts, vehicles, and fitment your store needs —
          without an ACES/PIES file of your own. ShowMeTheParts is operated by Vertical Development and aggregates
          parts data from <strong style="color: var(--text)">800+ supplier brands</strong>.
        </p>
        <div class="mt-8"><DualCTA variant="inline" /></div>
      </div>
      <div class="lg:col-span-5">
        <HeroVisual variant="data-sources" highlight={1} />
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="grid gap-5 sm:grid-cols-3">
      <div class="card text-center">
        <div class="font-display text-5xl font-extrabold tracking-tight" style="color: var(--primary)">800+</div>
        <div class="mt-2 text-sm" style="color: var(--text-muted)">Part brands available</div>
      </div>
      <div class="card text-center">
        <div class="font-display text-5xl font-extrabold tracking-tight" style="color: var(--primary)">24/7</div>
        <div class="mt-2 text-sm" style="color: var(--text-muted)">Updates from ShowMeTheParts</div>
      </div>
      <div class="card text-center">
        <div class="font-display text-5xl font-extrabold tracking-tight" style="color: var(--primary)">0</div>
        <div class="mt-2 text-sm" style="color: var(--text-muted)">Files to maintain yourself</div>
      </div>
    </div>
  </section>

  <section style="background: var(--surface-2)">
    <div class="section">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">What's supported</h2>
          <ul class="mt-6 space-y-3">
            {[
              'Parts and fitment sync via API',
              'VIN and license-plate lookup, where ShowMeTheParts provides it',
              'On-demand sync available',
              '800+ supplier brands across replacement, accessories, and performance categories',
            ].map((s) => (
              <li class="flex items-start gap-3">
                <span class="mt-1 inline-block h-2 w-2 flex-none rounded-full" style="background: var(--primary)"></span>
                <span style="color: var(--text)">{s}</span>
              </li>
            ))}
          </ul>
        </div>
        <aside class="lg:col-span-5">
          <div class="card" style="background: var(--primary-soft); border-color: color-mix(in srgb, var(--primary) 25%, transparent)">
            <span class="tag tag-primary">Who this fits</span>
            <p class="mt-3 text-sm" style="color: var(--text)">
              Retailers and aftermarket sellers who don't maintain their own catalog data but want
              manufacturer-grade fitment. The default for stores that aren't yet on ACES/PIES.
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <DualCTA headline="Book a demo using ShowMeTheParts." />

</BaseLayout>
