---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DualCTA from '../../components/DualCTA.astro';
import HeroVisual from '../../components/HeroVisual.astro';

const features = [
  { href: '/features/ymm-search/',           title: 'YMM Fitment Search',              body: 'Year-Make-Model dropdowns, a multi-vehicle garage, VIN lookup (where supported), and license-plate lookup (where supported), with in-stock and vendor-priority result sorting.' },
  { href: '/features/catalog-sync/',         title: 'Catalog Parts Sync',              body: "Push your catalog into Shopify products - Description, Specifications, Buyer's Guide, and Interchanges." },
  { href: '/features/pdp-enrichment/',       title: 'PDP Product Information',         body: "Fitment, attributes, specs, notes, and Buyer's Guide content on every product page, themed to match your store." },
  { href: '/features/in-cart-fitment/',      title: 'In-Cart Fitment & Fulfillment Handoff', body: "The shopper's selected vehicle follows them to checkout and to your fulfillment team. Ship the right part the first time.", isNew: true },
  { href: '/features/price-inventory-sync/', title: 'Price & Inventory Sync',          body: 'Pull price and inventory updates from FTP/SFTP or email and auto-hide out-of-stock products.' },
  { href: '/features/order-export/',         title: 'Order Export',                    body: 'Route orders to Email, FTP/SFTP, or API destinations by brand or SKU pattern. Customize the format for what your warehouse, ERP, or 3PL expects.' },
];
---

<BaseLayout
  title="SPT for Shopify — Features"
  description="The six modules that turn a generic Shopify store into a real automotive parts store. Fitment search, catalog sync, PDP enrichment, in-cart fitment, P&I sync, order export."
>

  <section class="section pt-12 sm:pt-20">
    <div class="grid items-center gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--action)">
          SPT for Shopify
        </p>
        <h1 class="mt-3 text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl" style="color: var(--text)">
          Everything a parts store on Shopify needs, in one toolkit.
        </h1>
        <p class="lede mt-5 max-w-2xl">
          SPT covers the six jobs that turn a generic Shopify store into a real automotive parts store — fitment search,
          catalog sync, product detail enrichment, in-cart fitment, price/inventory ingestion, and order export. Use the
          whole toolkit or pick the modules you need. One install per store.
        </p>
        <div class="mt-8"><DualCTA variant="inline" /></div>
      </div>
      <div class="lg:col-span-5">
        <HeroVisual variant="toolkit" />
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <a
          href={f.href}
          class="card focus-ring group relative block transition-shadow hover:shadow-lg"
          style={f.isNew ? 'border-left: 3px solid var(--action)' : undefined}
        >
          {f.isNew && (
            <span class="tag tag-action absolute right-4 top-4">New</span>
          )}
          <h2 class="pr-12 text-lg font-bold" style="color: var(--text)">{f.title}</h2>
          <p class="mt-2 text-sm" style="color: var(--text-muted)">{f.body}</p>
          <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors group-hover:gap-2" style="color: var(--primary)">
            Learn more <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="section pt-0">
    <div
      class="overflow-hidden rounded-3xl p-8 sm:p-12"
      style="background: var(--primary-soft); border: 1px solid color-mix(in srgb, var(--primary) 25%, transparent)"
    >
      <div class="flex flex-wrap items-center justify-between gap-6">
        <div class="max-w-2xl">
          <h2 class="text-2xl font-bold sm:text-3xl" style="color: var(--primary)">
            Configurable across the board.
          </h2>
          <p class="mt-3" style="color: var(--text)">
            Every widget exposes settings for layout, styling, and behavior so the it fits your
            store rather than the other way around.
          </p>
        </div>
        <a href="/integrations/" class="btn btn-secondary">See data sources →</a>
      </div>
    </div>
  </section>

  <DualCTA />

</BaseLayout>
