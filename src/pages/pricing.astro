---
import BaseLayout from '../layouts/BaseLayout.astro';
import DualCTA from '../components/DualCTA.astro';
import { SHOPIFY_APP_URL } from '../consts';

const compareRows = [
  ['YMM Fitment Search',                      '✓',    '✓'],
  ['Catalog Parts Sync',                      '✓',    '✓'],
  ["PDP Enrichment (incl. Buyer's Guide)",    '✓',    '✓'],
  ['In-Cart Fitment & Fulfillment Handoff',   '✓',    '✓'],
  ['Data sources (ACES/PIES, ShowMeTheParts, CSV)', '✓', '✓'],
  ['Free searches (lifetime)',                '100 total', 'Unlimited'],
  ['Automatic Price & Inventory sync',        '—',    '✓'],
  ['Order Export (Email / FTP / API)',        '—',    '✓'],
  ['Multiple order-export destinations',      '—',    '✓'],
  ['Support',                                 'Email & Chat', 'Priority'],
];

const faqs = [
  { q: 'What counts as a "search"?',          a: 'Every Year-Make-Model, VIN, or license-plate lookup performed by a shopper on your store. Product page loads don\'t count as searches.' },
  { q: 'What happens when I reach the 100-search lifetime cap?', a: 'Once the free allotment is used up, the search endpoint returns an upgrade prompt and nudges you to move to Pro, which restores unlimited searches. The free allotment is a lifetime total, not a monthly reset.' },
  { q: 'Is there a free trial of Pro?',       a: 'No, the free plan is meant to give you an introduction to the main components. Pro unlocked expanded searches and automations.' },
  { q: 'Do you charge per SKU?',              a: 'No. SKU counts aren\'t limited in either tier aside from any limitations Shopify places on your store by default.' },
  { q: 'Can I switch tiers?',                 a: 'Yes, you can downgrade by reaching out to our team.' },
  { q: 'What about the Merchant of Record service?', a: 'MoR is a separate service from the SPT app. Pricing is transaction-based and quoted per merchant. See the MoR page for details.' },
];
---

<BaseLayout
  title="Pricing — SPT"
  description="Two tiers. Free with a 100-search lifetime cap, or Pro at $300/month for unlimited searches, P&I sync, and order export. No tiers in between."
>

  <section class="section pt-12 sm:pt-20">
    <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--action)">Pricing</p>
    <h1 class="mt-3 max-w-4xl text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl" style="color: var(--text)">
      Two tiers. No surprises.
    </h1>
    <p class="lede mt-5 max-w-3xl">
    Start free, upgrade to unlock unlimited searches, automatic price/inventory sync and order export. Every plan includes the
      same YMM search, catalog sync, PDP enrichment, and in-cart fitment.
    </p>
  </section>

  <section class="section pt-0">
    <div class="grid gap-6 lg:grid-cols-2">

      <!-- Free -->
      <article class="card flex flex-col">
        <header>
          <span class="tag">Free</span>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="font-display text-5xl font-extrabold tracking-tight" style="color: var(--text)">$0</span>
            <span style="color: var(--text-muted)">/ month</span>
          </div>
          <p class="mt-3" style="color: var(--text-muted)">
            For trying SPT, piloting a small catalog, or a low-traffic store.
          </p>
        </header>
        <ul class="mt-6 space-y-2.5 text-sm" style="color: var(--text)">
          {[
            ['inc', 'YMM Fitment Search'],
            ['inc', 'Single Brand Catalog Parts Sync'],
            ['inc', "PDP Enrichment (incl. Buyer's Guide)"],
            ['inc', 'In-Cart Fitment & Fulfillment Handoff'],
            ['inc', 'ACES/PIES, ShowMeTheParts, or CSV data source'],
            ['lim', 'Capped at 100 searches total (lifetime)'],
            ['no',  'No automatic Price & Inventory sync'],
            ['no',  'No Order Export'],
            ['inc', 'Email & Chat support'],
          ].map(([kind, text]) => (
            <li class="flex items-start gap-2">
              {kind === 'inc' && (<span class="mt-0.5 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full" style="background: var(--primary-soft); color: var(--primary)">✓</span>)}
              {kind === 'lim' && (<span class="mt-0.5 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full" style="background: var(--spark-soft); color: var(--spark)">!</span>)}
              {kind === 'no'  && (<span class="mt-0.5 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full" style="background: var(--surface-2); color: var(--text-subtle)">−</span>)}
              <span>{text}</span>
            </li>
          ))}
        </ul>
        <div class="mt-7">
          <a href={SHOPIFY_APP_URL} target="_blank" rel="noopener" class="btn btn-secondary w-full">Install on Shopify (free)</a>
        </div>
      </article>

      <!-- Pro -->
      <article class="card relative flex flex-col" style="border: 2px solid var(--primary)">
        <span class="absolute -top-3 left-6 inline-flex items-center rounded-full px-3 py-0.5 text-xs font-semibold uppercase tracking-wider" style="background: var(--primary); color: var(--primary-fg)">Most popular</span>
        <header>
          <span class="tag tag-primary">Pro · All features</span>
          <div class="mt-4 flex items-baseline gap-2">
            <span class="font-display text-5xl font-extrabold tracking-tight" style="color: var(--text)">$300</span>
            <span style="color: var(--text-muted)">/ month</span>
          </div>
          <p class="mt-3" style="color: var(--text-muted)">
            For larger stores.
          </p>
        </header>
        <ul class="mt-6 space-y-2.5 text-sm" style="color: var(--text)">
          {[
            'Everything in Free',
            'Unlimited searches',
            'Automatic Price & Inventory sync (FTP/SFTP or email)',
            'Order Export (Email / FTP / API)',
            'Multiple order-export destinations',
            'Priority support',
          ].map((text) => (
            <li class="flex items-start gap-2">
              <span class="mt-0.5 inline-flex h-5 w-5 flex-none items-center justify-center rounded-full" style="background: var(--primary-soft); color: var(--primary)">✓</span>
              <span>{text}</span>
            </li>
          ))}
        </ul>
        <div class="mt-7">
          <a href={SHOPIFY_APP_URL} target="_blank" rel="noopener" class="btn btn-primary w-full">Install on Shopify</a>
        </div>
      </article>

    </div>
  </section>

  <!-- See with your data -->
  <DualCTA />

  <!-- Comparison table -->
  <section style="background: var(--surface-2)">
    <div class="section">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Side-by-side comparison</h2>
      <div class="mt-6 overflow-hidden rounded-2xl border" style="border-color: var(--border); background: var(--surface)">
        <table class="w-full text-left text-sm">
          <thead>
            <tr style="background: var(--surface-2)">
              <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider" style="color: var(--text-subtle)">Feature</th>
              <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider" style="color: var(--text-subtle)">Free</th>
              <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider" style="color: var(--text-subtle)">Pro · $300/mo</th>
            </tr>
          </thead>
          <tbody>
            {compareRows.map(([feature, free, pro], i) => (
              <tr style={i % 2 === 1 ? 'background: var(--surface-2)' : undefined}>
                <td class="px-5 py-3" style="color: var(--text)">{feature}</td>
                <td class="px-5 py-3" style="color: var(--text-muted)">{free}</td>
                <td class="px-5 py-3" style="color: var(--text)"><strong>{pro}</strong></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- MoR callout -->
  <section class="section">
    <div
      class="overflow-hidden rounded-3xl border p-8 sm:p-12"
      style="border-color: color-mix(in srgb, var(--action) 25%, transparent); background: var(--action-soft)"
    >
      <div class="flex flex-wrap items-center justify-between gap-6">
        <div class="max-w-2xl">
          <span class="tag tag-action">Sold separately</span>
          <h2 class="mt-3 text-2xl font-bold sm:text-3xl" style="color: var(--text)">
            Need sales tax handled, too?
          </h2>
          <p class="mt-3" style="color: var(--text-muted)">
            The SPT Merchant of Record service is sold separately — pricing is transaction-based and quoted per
            merchant.
          </p>
        </div>
        <a href="/merchant-of-record/" class="btn btn-primary">Talk to us →</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="background: var(--surface-2)">
    <div class="section">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Pricing FAQ</h2>
      <dl class="mt-8 grid gap-4 sm:grid-cols-2">
        {faqs.map((f) => (
          <div class="card">
            <dt class="text-base font-semibold" style="color: var(--text)">{f.q}</dt>
            <dd class="mt-2 text-sm" style="color: var(--text-muted)">{f.a}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

</BaseLayout>
