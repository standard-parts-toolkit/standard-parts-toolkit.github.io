---
import BaseLayout from '../layouts/BaseLayout.astro';
import DualCTA from '../components/DualCTA.astro';
import JsonLd from '../components/JsonLd.astro';
import LogoWall from '../components/LogoWall.astro';
import HeroVisual from '../components/HeroVisual.astro';

const softwareApp = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'SPT — Standard Parts Toolkit',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Shopify',
  description: "SPT turns ACES/PIES, ShowMeTheParts, or CSV data into fast Year-Make-Model search, enriched product pages, in-cart fitment, and order plumbing for Shopify automotive parts stores.",
  url: 'https://www.standardpartstoolkit.com/',
  offers: [
    { '@type': 'Offer', name: 'Free',  price: '0',   priceCurrency: 'USD', description: 'Capped at 100 searches total. No automatic P&I sync or Order Export.' },
    { '@type': 'Offer', name: 'Pro',   price: '300', priceCurrency: 'USD', description: 'All features. Unlimited searches. Automatic P&I sync and Order Export included.' },
  ],
  provider: {
    '@type': 'Organization',
    name: 'No Fixed Plans',
    url: 'https://nofixedplans.xyz/',
  },
};

const features = [
  {
    title: 'YMM Fitment Search',
    body: 'Year-Make-Model dropdowns, a multi-vehicle garage, VIN lookup (where supported), and license-plate lookup (where supported), with in-stock and vendor-priority result sorting.',
    href: '/features/ymm-search/',
  },
  {
    title: 'Catalog Parts Sync',
    body: "Push your catalog into Shopify products - Description, Specifications, Buyer's Guide, and Interchanges.",
    href: '/features/catalog-sync/',
  },
  {
    title: 'PDP Product Information',
    body: "Fitment, attributes, specs, notes, and Buyer's Guide content on every product page, themed to match your store.",
    href: '/features/pdp-enrichment/',
  },
  {
    title: 'In-Cart Fitment & Fulfillment Handoff',
    body: "The shopper's selected vehicle follows them to checkout and to your fulfillment team. Ship the right part the first time.",
    href: '/features/in-cart-fitment/',
    isNew: true,
  },
  {
    title: 'Price & Inventory Sync',
    body: 'Pull price and inventory updates from FTP/SFTP or email and auto-hide out-of-stock products.',
    href: '/features/price-inventory-sync/',
  },
  {
    title: 'Order Export',
    body: 'Route orders to Email, FTP/SFTP, or API destinations by brand or SKU pattern. Customize the format for what your warehouse, ERP, or 3PL expects.',
    href: '/features/order-export/',
  },
];
---

<BaseLayout
  title="SPT — Standard Parts Toolkit for Shopify"
  description="SPT turns ACES/PIES, ShowMeTheParts, or CSV data into fast YMM search, enriched product pages, in-cart fitment, and order plumbing. Built to reduce 'didn't fit' returns."
>
  <JsonLd slot="head" data={softwareApp} />


  <!-- ============ HERO ============ -->
  <section class="section pt-12 sm:pt-20">
    <div class="grid items-center gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--action)">
          Built for automotive parts on Shopify
        </p>

        <h1
          class="mt-3 text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl"
          style="color: var(--text)"
        >
        Zero-Touch Fitment Search / Catalog Management on Shopify.
        </h1>

        <p class="lede mt-5 max-w-2xl">
          <strong>SPT</strong> — Standard Parts Toolkit — gives your Shopify store the fitment search,
          catalog sync, PDP enrichment, in-cart fitment, and inventory management it needs to sell auto parts the way buyers
          actually shop for them. Built for parts manufacturers selling direct-to-consumer and for automotive retailers alike to reduce
          fitment and administration issues so you can sell more parts.
        </p>

        <div class="mt-8">
          <DualCTA variant="inline" />
        </div>

        <!-- Compatibility badges -->
        <ul class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm" style="color: var(--text-muted)">
          <li class="inline-flex items-center gap-2">
            <span class="inline-block h-2 w-2 rounded-full" style="background: var(--primary)"></span>
            <strong style="color: var(--text)">Shopify Online Store 2.0</strong> compatible
          </li>
          <li class="inline-flex items-center gap-2">
            <span class="inline-block h-2 w-2 rounded-full" style="background: var(--primary)"></span>
            <strong style="color: var(--text)">No custom dev work</strong> required
          </li>
          <li class="inline-flex items-center gap-2">
            <span class="inline-block h-2 w-2 rounded-full" style="background: var(--primary)"></span>
            <strong style="color: var(--text)">One click install</strong>
          </li>
        </ul>
      </div>

      <div class="lg:col-span-5">
        <HeroVisual />
      </div>
    </div>
  </section>

  <!-- ============ TRUST STRIP ============ -->
  <section class="border-y" style="background: var(--surface-2); border-color: var(--border)">
    <div class="mx-auto max-w-7xl px-6 py-8 sm:px-8">
      <p class="text-center text-xs font-semibold uppercase tracking-wider" style="color: var(--text-subtle)">
        Trusted by manufacturers and retailers selling automotive parts on Shopify
      </p>
      <LogoWall />
    </div>
  </section>

  <!-- ============ SIX-FEATURE GRID ============ -->
  <section class="section">
    <div class="max-w-3xl">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">One toolkit, six jobs done right.</h2>
      <p class="lede mt-3">
        Every module is configurable on its own, and every module reads from the same source of truth.
      </p>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <a
          href={f.href}
          class="card focus-ring group relative block transition-shadow hover:shadow-lg"
          style={f.isNew ? 'border-left: 3px solid var(--action)' : undefined}
        >
          {f.isNew && (
            <span class="tag tag-action absolute right-4 top-4">New</span>
          )}
          <h3 class="pr-12 text-lg font-bold" style="color: var(--text)">{f.title}</h3>
          <p class="mt-2 text-sm" style="color: var(--text-muted)">{f.body}</p>
          <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors group-hover:gap-2" style="color: var(--primary)">
            Learn more <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>

  </section>

  <!-- ============ DATA SOURCES SECTION ============ -->
  <section class="section pt-0">
    <div class="max-w-3xl">
      <span class="tag tag-spark">Data-source agnostic</span>
      <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">Bring the data you already have.</h2>
      <p class="lede mt-3">
        SPT speaks three industry-standard parts-data formats. Pick the one that matches how you already operate
        today. Switch later without rebuilding your storefront.
      </p>
    </div>

    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      <a href="/integrations/aces-pies/" class="card focus-ring group block transition-shadow hover:shadow-lg">
        <span class="tag tag-primary">Manufacturer-grade</span>
        <h3 class="mt-3 text-lg font-bold" style="color: var(--text)">ACES / PIES XML</h3>
        <p class="mt-2 text-sm" style="color: var(--text-muted)">
          The industry-standard XML formats from the AutoCare Association. ACES describes which vehicles each part
          fits; PIES describes the parts themselves. Send files to us and we'll parses, validate, and sync them with your store.
        </p>
        <ul class="mt-4 space-y-1.5 text-xs" style="color: var(--text-subtle)">
          <li>· ACES 3.x and 4.x fitment</li>
          <li>· PIES 6.x and 7.x product information</li>
          <li>· Full + incremental updates</li>
        </ul>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors group-hover:gap-2" style="color: var(--primary)">
          ACES/PIES details <span aria-hidden="true">→</span>
        </span>
      </a>

      <a href="/integrations/showmetheparts/" class="card focus-ring group block transition-shadow hover:shadow-lg">
        <span class="tag">API-driven</span>
        <h3 class="mt-3 text-lg font-bold" style="color: var(--text)">ShowMeTheParts</h3>
        <p class="mt-2 text-sm" style="color: var(--text-muted)">
          Connect your ShowMeTheParts account and SPT will sync the parts, vehicles, and fitment your store needs
          without maintaining an ACES/PIES feed of your own.
        </p>
        <ul class="mt-4 space-y-1.5 text-xs" style="color: var(--text-subtle)">
          <li>· VIN + license-plate lookup</li>
          <li>· On-demand re-sync</li>
        </ul>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors group-hover:gap-2" style="color: var(--primary)">
          ShowMeTheParts details <span aria-hidden="true">→</span>
        </span>
      </a>

      <a href="/integrations/csv/" class="card focus-ring group block transition-shadow hover:shadow-lg">
        <span class="tag">Lightweight</span>
        <h3 class="mt-3 text-lg font-bold" style="color: var(--text)">CSV</h3>
        <p class="mt-2 text-sm" style="color: var(--text-muted)">
          A spreadsheet is enough to get started. If you have a CSV of parts, vehicles, and fitment, you have
          everything SPT needs to power YMM search, catalog sync, and PDP enrichment.
        </p>
        <ul class="mt-4 space-y-1.5 text-xs" style="color: var(--text-subtle)">
          <li>· Combined or separate files</li>
          <li>· Configurable column mapping</li>
          <li>· Validation report on each upload</li>
        </ul>
        <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold transition-colors group-hover:gap-2" style="color: var(--primary)">
          CSV details <span aria-hidden="true">→</span>
        </span>
      </a>
    </div>

    <p class="mt-6 text-sm" style="color: var(--text-subtle)">
      All three connect into the same configuration:your YMM widget, PDP blocks, and admin settings carry over if
      you switch sources later.
    </p>
  </section>

  <!-- ============ REDUCE RETURNS BAND ============ -->
  <section style="background: var(--surface-2)">
    <div class="section">
      <div class="grid items-center gap-10 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <span class="tag tag-action">Reduce returns</span>
          <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
            Stop refunding parts that didn't fit.
          </h2>
          <p class="lede mt-4 max-w-2xl">
          Generic Shopify search doesn't know which cataltyic converter fits a 2014 Silverado. SPT does, and it carries
            that knowledge from the search box, to the product page, to the cart, to the order your warehouse pulls.
            Fitment verified on the product page and the selected vehicle following the order means fewer returns,
            fewer chargebacks, and shoppers who trust your store the second time.
          </p>
        </div>
        <div class="lg:col-span-5">
          <ol class="space-y-3">
            {[
              ['Search', 'Shopper picks a vehicle. It\'s saved to their session.'],
              ['Product page', 'Fitment, Buyer\'s Guide, and notes render from the same data feed.'],
              ['Cart', 'The vehicle travels as line-item properties, visible in the cart and order summary.'],
              ['Fulfillment', 'Your team sees the exact vehicle on the order before pick and pack.'],
            ].map(([step, body], i) => (
              <li class="flex gap-4">
                <span
                  class="mt-0.5 inline-flex h-7 w-7 flex-none items-center justify-center rounded-full text-xs font-bold"
                  style="background: var(--primary); color: var(--primary-fg)"
                >{i + 1}</span>
                <div>
                  <div class="text-sm font-semibold" style="color: var(--text)">{step}</div>
                  <div class="text-sm" style="color: var(--text-muted)">{body}</div>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ MANUFACTURER VS RETAILER ============ -->
  <section class="section">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Two audiences, one toolkit.</h2>
    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <div class="card">
        <span class="tag tag-primary">For parts manufacturers</span>
        <p class="mt-4 text-base" style="color: var(--text)">
          You already maintain a clean catalog in ACES/PIES. SPT gets that catalog onto your own direct-to-consumer
          Shopify store, accurately, on the cadence you control, with orders exported back to the systems you
          already run. Sell direct without a custom build and without rebuilding your data infrastructure.
        </p>
        <a href="/features/catalog-sync/" class="mt-5 inline-flex items-center gap-1 text-sm font-semibold" style="color: var(--primary)">
          See it for manufacturers <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="card">
        <span class="tag">For automotive retailers</span>
        <p class="mt-4 text-base" style="color: var(--text)">
          You sell parts. Your customers need to find the one that fits their vehicle. Plug in data from CSV, ShowMeTheParts, or
          your suppliers ACES/PIES data, and your storefront ships with proper fitment search, fitment-aware product
          pages, and price/inventory sync in days.
        </p>
        <a href="/features/ymm-search/" class="mt-5 inline-flex items-center gap-1 text-sm font-semibold" style="color: var(--primary)">
          See it for retailers <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ SCREENSHOTS + DEMO LINK ============ -->
  <section style="background: var(--surface-2)">
    <div class="section">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div class="max-w-2xl">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">See it in production.</h2>
        </div>
        <a href="https://carmenspartdepot.com" target="_blank" rel="noopener" class="btn btn-secondary">
          View Demo Site <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="mt-8 grid gap-5 sm:grid-cols-3">
        {[
          { src: '/screenshots/ymm_category_search.png', label: 'YMM search on a category page' },
          { src: '/screenshots/buyers_guide.png',        label: 'Fitment table on a product detail page' },
          { src: '/screenshots/cart_fitment.png',        label: 'Fitment confirmed in the cart' },
        ].map(({ src, label }) => (
          <figure class="overflow-hidden rounded-2xl border" style="border-color: var(--border); background: var(--surface)">
            <img
              src={src}
              alt={label}
              width="1200"
              height="900"
              loading="lazy"
              class="aspect-[4/3] w-full object-cover"
            />
            <figcaption class="px-4 py-3 text-sm" style="color: var(--text-muted)">{label}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ BY THE NUMBERS ============ -->
  <section class="section">
    <div class="grid gap-6 sm:grid-cols-3">
      {[
        ['3',    'Data sources, your choice'],
        ['24/7', 'Updates from your data feed'],
        ['0',    'Hours you spend managing fitment data'],
      ].map(([value, label]) => (
        <div class="card text-center">
          <div class="font-display text-5xl font-extrabold tracking-tight" style="color: var(--primary)">{value}</div>
          <div class="mt-2 text-sm" style="color: var(--text-muted)">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ TESTIMONIAL ============ -->
  <section class="section pt-0">
    <figure class="mx-auto max-w-3xl text-center">
      <blockquote
        class="relative text-xl font-medium leading-snug sm:text-2xl"
        style="color: var(--text)"
      >
        <span aria-hidden="true" class="absolute -left-6 -top-4 text-7xl leading-none sm:-left-10" style="color: var(--spark)">“</span>
        Been working with Standard Parts Toolkit for a few years now and couldn't be happier. Their fitment toolbar has been a game changer for us. Our customers appreciate the ease in finding the right parts for their vehicle. We've really appreciated how easy it is to work with SPT and how responsive they are. Definitely recommend!
      </blockquote>
      <figcaption class="mt-6 text-sm" style="color: var(--text-muted)">
        <span class="font-semibold" style="color: var(--text)">Luke Smith</span>, CEO, Momentum USA, Inc.
      </figcaption>
    </figure>
  </section>

  <!-- ============ MERCHANT OF RECORD CALLOUT ============ -->
  <section class="section pt-0">
    <div
      class="overflow-hidden rounded-3xl border p-8 sm:p-12"
      style="border-color: color-mix(in srgb, var(--action) 25%, transparent); background: var(--action-soft)"
    >
      <div class="flex flex-wrap items-center justify-between gap-6">
        <div class="max-w-2xl">
          <span class="tag tag-action">Sales Tax Solution</span>
          <h2 class="mt-3 text-2xl font-bold sm:text-3xl" style="color: var(--text)">
            Worried about how to handle sales tax? We can be your merchant of record.
          </h2>
          <p class="mt-3" style="color: var(--text-muted)">
            Outsource sales tax collection, remittance, and reporting so you can focus on growing your parts business.
          </p>
        </div>
        <a href="/merchant-of-record/" class="btn btn-primary">Learn about MoR →</a>
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA BAND ============ -->
  <DualCTA />

</BaseLayout>
