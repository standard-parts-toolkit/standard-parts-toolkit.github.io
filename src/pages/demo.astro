---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { FORMSPREE_DEMO_ID } from '../consts';

const formId = FORMSPREE_DEMO_ID;
---

<BaseLayout
  title="Book a Demo — SPT"
  description="A demo isn't a sales call with slides. We run a sample of your ACES/PIES file, ShowMeTheParts feed, or CSV through the toolkit and walk you through the result."
>

  <section class="section pt-12 sm:pt-20">
    <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--action)">Book a Demo</p>
    <h1 class="mt-3 max-w-4xl text-4xl font-extrabold leading-[1.1] tracking-tight sm:text-5xl lg:text-6xl" style="color: var(--text)">
      See it on your data.
    </h1>
    <p class="lede mt-5 max-w-3xl">
      A demo isn't a sales call with slides. We run a sample of your ACES/PIES file, ShowMeTheParts feed, or CSV
      through the toolkit, then walk you through the resulting YMM search and product pages — typically in 30
      minutes.
    </p>
  </section>

  <section class="section pt-0">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <ContactForm
          formId={formId}
          submitLabel="Request a demo"
          successMessage="Thanks — we'll be in touch within one business day to schedule a time and let you know what data sample to share."
          reassurance="We won't add you to a marketing drip. We won't share your data with anyone."
          fields={[
            { name: 'name',         label: 'Name',            required: true },
            { name: 'company',      label: 'Company',         required: true },
            { name: 'role',         label: 'Role',            required: true },
            { name: 'email',        label: 'Work email',      type: 'email', required: true },
            { name: 'store_url',    label: 'Shopify store URL (if you have one)', type: 'url', span: 2 },
            { name: 'data_source',  label: 'Primary data source', type: 'select', required: true,
              options: ['ACES/PIES', 'ShowMeTheParts', 'CSV', 'Not sure yet'] },
            { name: 'catalog_size', label: 'Approximate catalog size (SKUs)', type: 'number', required: true },
            { name: 'primary_goal', label: 'Primary goal',    type: 'textarea', required: true, span: 2,
              placeholder: 'What problem are you trying to solve with SPT?' },
            { name: 'notes',        label: 'Anything else we should know? (optional)', type: 'textarea', span: 2 },
          ]}
        />
      </div>
      <aside class="lg:col-span-5">
        <div class="card">
          <h2 class="text-base font-bold" style="color: var(--text)">What to expect</h2>
          <ul class="mt-4 space-y-3 text-sm" style="color: var(--text)">
            <li class="flex gap-3">
              <span class="mt-1 inline-block h-2 w-2 flex-none rounded-full" style="background: var(--primary)"></span>
              <span>We respond within one business day to schedule.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 inline-block h-2 w-2 flex-none rounded-full" style="background: var(--primary)"></span>
              <span>We'll ask for a small data sample we can run through SPT.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 inline-block h-2 w-2 flex-none rounded-full" style="background: var(--primary)"></span>
              <span>30-minute call: real YMM results from your data, your PDP attributes, and your questions.</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-1 inline-block h-2 w-2 flex-none rounded-full" style="background: var(--primary)"></span>
              <span>If we're not a fit, we'll tell you.</span>
            </li>
          </ul>
        </div>

        <div class="card mt-5">
          <h2 class="text-base font-bold" style="color: var(--text)">Prefer to just look around?</h2>
          <p class="mt-2 text-sm" style="color: var(--text-muted)">
            Browse a real Shopify storefront running SPT.
          </p>
          <a
            href="https://carmenspartdepot.com"
            target="_blank"
            rel="noopener"
            class="btn btn-secondary mt-3 w-full"
          >View Demo Site →</a>
        </div>
      </aside>
    </div>
  </section>

</BaseLayout>
