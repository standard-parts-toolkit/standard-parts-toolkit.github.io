---
import { GA4_ID as GA_ID } from '../consts';
---

{GA_ID && (
  <aside
    id="spt-consent"
    class="fixed inset-x-3 bottom-3 z-50 mx-auto hidden max-w-2xl rounded-2xl border p-4 shadow-lg sm:p-5"
    style="background: var(--surface); border-color: var(--border-strong)"
    role="dialog"
    aria-live="polite"
    aria-label="Cookie consent"
  >
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-5">
      <div class="flex-1 text-sm" style="color: var(--text)">
        <strong class="block text-base">Cookies</strong>
        <span style="color: var(--text-muted)">
          We use Google Analytics to understand how the site is used. No marketing or advertising trackers. The
          site works either way.
        </span>
      </div>
      <div class="flex flex-none gap-2">
        <button type="button" data-consent="declined" class="btn btn-secondary">Decline</button>
        <button type="button" data-consent="accepted" class="btn btn-primary">Accept</button>
      </div>
    </div>
  </aside>

  <script is:inline>
    (function () {
      const el = document.getElementById('spt-consent');
      if (!el) return;
      let saved = null;
      try { saved = localStorage.getItem('spt-consent'); } catch (_) {}
      if (!saved) el.classList.remove('hidden');

      el.querySelectorAll('[data-consent]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const choice = btn.getAttribute('data-consent');
          try { localStorage.setItem('spt-consent', choice); } catch (_) {}
          el.classList.add('hidden');
          if (choice === 'accepted') {
            window.dispatchEvent(new Event('spt:consent-accepted'));
          }
        });
      });
    })();
  </script>
)}
