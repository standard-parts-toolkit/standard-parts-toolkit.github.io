---
import { SHOPIFY_APP_URL } from '../consts';
interface Props {
  headline?: string;
  subhead?: string;
  showDemoLink?: boolean;
  variant?: 'band' | 'inline';
}
const {
  headline = 'See it on your data.',
  subhead = "We'll run a short demo against a sample of your ACES/PIES file, ShowMeTheParts feed, or CSV — so you can see real fitment results before you decide.",
  showDemoLink = true,
  variant = 'band',
} = Astro.props;
---

{variant === 'band' && (
  <section class="section">
    <div
      class="overflow-hidden rounded-3xl px-8 py-14 text-center sm:px-12"
      style="background: linear-gradient(135deg, var(--primary), color-mix(in srgb, var(--primary) 70%, black))"
    >
      <h2 class="text-3xl font-bold text-white sm:text-4xl">{headline}</h2>
      <p class="mx-auto mt-3 max-w-2xl text-base text-white/85 sm:text-lg">{subhead}</p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a href="/demo/" class="btn btn-primary">Book a Demo</a>
        <a href={SHOPIFY_APP_URL} target="_blank" rel="noopener" class="btn" style="background: white; color: var(--primary)">Install on Shopify</a>
        {showDemoLink && (
          <a href="https://carmenspartdepot.com" target="_blank" rel="noopener" class="btn" style="background: transparent; color: white; border: 1px solid color-mix(in srgb, white 50%, transparent)">
            View Demo Site <span aria-hidden="true">→</span>
          </a>
        )}
      </div>
    </div>
  </section>
)}

{variant === 'inline' && (
  <div class="flex flex-wrap items-center gap-3">
    <a href="/demo/" class="btn btn-primary">Book a Demo</a>
    <a href={SHOPIFY_APP_URL} target="_blank" rel="noopener" class="btn btn-secondary">Install on Shopify</a>
    {showDemoLink && (
      <a href="https://carmenspartdepot.com" target="_blank" rel="noopener" class="btn btn-ghost">
        View Demo Site <span aria-hidden="true">→</span>
      </a>
    )}
  </div>
)}
